#!/usr/bin/env python3
"""rkllama-pull — manage RKLLM models on the cluster.

Usage:
    rkllama-pull [search terms ...]   # search HuggingFace and pull a model
    rkllama-pull --delete             # list installed models and delete one

Prerequisites:
    - kubectl configured to reach the cluster (kubeconfig in place)
    - huggingface-hub Python package  (pip install huggingface-hub)
"""

import subprocess
import sys


def _choose(prompt: str, items: list) -> str:
    for i, item in enumerate(items, 1):
        print(f"  {i:2d}.  {item}")
    print()
    while True:
        try:
            idx = int(input(f"{prompt} [1-{len(items)}]: ").strip()) - 1
            if 0 <= idx < len(items):
                return items[idx]
        except (ValueError, KeyboardInterrupt):
            pass
        print(f"  Please enter a number between 1 and {len(items)}.")


def _resolve_pod() -> str:
    try:
        pod_output = subprocess.check_output(
            [
                "kubectl",
                "get",
                "pod",
                "-n",
                "rkllama",
                "-l",
                "app=rkllama",
                "-o",
                "name",
            ],
            text=True,
        ).strip()
    except subprocess.CalledProcessError as e:
        print(f"ERROR: Could not list rkllama pods: {e}")
        sys.exit(1)
    if not pod_output:
        print(
            "ERROR: No rkllama pod found. Is the cluster reachable and rkllama running?"
        )
        sys.exit(1)
    pod = pod_output.split("\n")[0]
    print(f"Using: {pod}")
    return pod


def _kubectl_exec(pod: str, *cmd: str, capture: bool = False):
    args = ["kubectl", "exec", "-n", "rkllama", pod, "-c", "rkllama", "--"] + list(cmd)
    if capture:
        return subprocess.check_output(args, text=True)
    return subprocess.run(args)


def do_delete() -> None:
    print("\nResolving rkllama pod ...")
    pod = _resolve_pod()

    print("\nFetching installed models ...")
    try:
        raw = _kubectl_exec(pod, "rkllama", "list", capture=True)
    except subprocess.CalledProcessError as e:
        print(f"ERROR: rkllama list failed: {e}")
        sys.exit(1)

    # Parse model names — lines look like "- modelname"
    models = []
    for line in raw.splitlines():
        stripped = line.strip()
        if stripped.startswith("- "):
            models.append(stripped[2:].strip())

    if not models:
        print("No models installed.")
        sys.exit(0)

    print(f"\nInstalled models:\n")
    name = _choose("Select model to delete", models)

    confirm = input(f"\nDelete '{name}'? [y/N]: ").strip().lower()
    if confirm != "y":
        print("Aborted.")
        sys.exit(0)

    result = _kubectl_exec(pod, "rkllama", "rm", name)
    if result.returncode != 0:
        print(f"\nERROR: rkllama rm exited with code {result.returncode}")
        sys.exit(result.returncode)

    print(f"\nDeleted '{name}'. Open WebUI will reflect the change within ~30 seconds.")


def do_pull() -> None:
    try:
        from huggingface_hub import HfApi
    except ImportError:
        print("ERROR: huggingface-hub is not installed.")
        print("       Run: uv pip install huggingface-hub")
        sys.exit(1)

    query = " ".join(sys.argv[1:]).strip()
    if not query:
        query = input("Search HuggingFace for RKLLM models: ").strip()
    if not query:
        print("No search query provided.")
        sys.exit(1)

    search_term = f"{query} rk3588 rkllm"
    print(f"\nSearching HuggingFace for: {search_term!r} ...")

    api = HfApi()
    repos = list(api.list_models(search=search_term, limit=20))
    if not repos:
        print("No models found. Try different search terms.")
        sys.exit(1)

    print(f"\nFound {len(repos)} repo(s):\n")
    repo_id = _choose("Select repo", [r.id for r in repos])

    print(f"\nFetching file list from {repo_id} ...")
    rkllm_files = [f for f in api.list_repo_files(repo_id) if f.endswith(".rkllm")]
    if not rkllm_files:
        print(f"No .rkllm files found in {repo_id}.")
        sys.exit(1)

    print(f"\nAvailable .rkllm files:\n")
    selected_file = _choose("Select file", rkllm_files)

    model_path = f"{repo_id}/{selected_file}"

    print(f"\nResolving rkllama pod ...")
    pod = _resolve_pod()

    # The rkllama server's /pull API has a bug that breaks when the repo name
    # contains the filename (its replace() strips all occurrences). Download
    # directly from HuggingFace into the pod's models directory instead.
    model_name = selected_file.replace(".rkllm", "")
    model_dir = f"/root/RKLLAMA/models/{model_name}"
    dest = f"{model_dir}/{selected_file}"
    url = f"https://huggingface.co/{repo_id}/resolve/main/{selected_file}"

    # Create model directory
    _kubectl_exec(pod, "mkdir", "-p", model_dir)

    # Check if already present
    check = subprocess.run(
        ["kubectl", "exec", "-n", "rkllama", pod, "-c", "rkllama", "--", "test", "-f", dest]
    )
    if check.returncode == 0:
        overwrite = input(f"\n'{selected_file}' already exists. Re-download? [y/N]: ").strip().lower()
        if overwrite != "y":
            print("Skipped.")
            return

    print(f"\nDownloading: {selected_file}")
    print(f"From: {url}")
    print("(Large models may take several minutes)\n")

    # Download — remove partial file first (HuggingFace XET doesn't support range requests)
    _kubectl_exec(pod, "rm", "-f", dest)
    result = _kubectl_exec(pod, "wget", "-O", dest, url)
    if result.returncode != 0:
        print(f"\nERROR: Download failed (exit {result.returncode})")
        sys.exit(result.returncode)

    # Write Modelfile so rkllama discovers the model
    modelfile_content = (
        f'FROM="{selected_file}"\n'
        f'\n'
        f'HUGGINGFACE_PATH="{repo_id}"\n'
        f'\n'
        f'SYSTEM=""\n'
        f'\n'
        f'TEMPERATURE=1.0\n'
    )
    _kubectl_exec(pod, "sh", "-c", f"cat > {model_dir}/Modelfile << 'MEOF'\n{modelfile_content}MEOF")

    print(f"\nDownloaded to {dest}")

    print("\n--- Installed models ---")
    _kubectl_exec(pod, "rkllama", "list")

    print("\nDone. Open WebUI will pick up the new model within ~30 seconds.")


def main() -> None:
    if "--delete" in sys.argv or "-d" in sys.argv:
        do_delete()
    else:
        do_pull()


if __name__ == "__main__":
    main()
