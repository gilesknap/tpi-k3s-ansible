#!/usr/bin/env python3
"""Generate all cluster secrets fresh for a rebuild.

External credentials (GitHub OAuth, Cloudflare tokens) are read from
environment variables. Everything else (admin passwords, cookie secrets,
Supabase JWTs, Dex client secrets) is generated randomly.

Outputs a JSON file in the same format as extracted-secrets.json, suitable
for consumption by `just seal-from-json` and `just seal-argocd-dex`, or
by the unified `just generate-and-seal-all` recipe.

Usage:
    scripts/generate-secrets [OUTPUT_DIR]

Required env vars:
    GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET    — Dex GitHub OAuth app
    CLOUDFLARE_API_TOKEN                       — cert-manager DNS solver
    CLOUDFLARE_TUNNEL_TOKEN                    — cloudflared tunnel
    OAUTH2_PROXY_CLIENT_ID                     — oauth2-proxy GitHub OAuth app
    OAUTH2_PROXY_CLIENT_SECRET                 — oauth2-proxy GitHub OAuth app
    OPEN_BRAIN_GITHUB_CLIENT_ID                — open-brain-mcp GitHub OAuth app
    OPEN_BRAIN_GITHUB_CLIENT_SECRET            — open-brain-mcp GitHub OAuth app

Optional env vars:
    ADMIN_PASSWORD     — shared admin password (generated if not set)
    SLACK_WEBHOOK_URL  — Alertmanager Slack notification webhook (empty if not set)
    SMTP_USERNAME      — Supabase SMTP (empty if not set)
    SMTP_PASSWORD      — Supabase SMTP (empty if not set)
    OPENAI_API_KEY     — Supabase OpenAI (empty if not set)
"""

from __future__ import annotations

import base64
import hashlib
import hmac
import json
import os
import secrets
import subprocess
import sys
import time
from pathlib import Path

REQUIRED_ENV = [
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_TUNNEL_TOKEN",
    "OAUTH2_PROXY_CLIENT_ID",
    "OAUTH2_PROXY_CLIENT_SECRET",
    "OPEN_BRAIN_GITHUB_CLIENT_ID",
    "OPEN_BRAIN_GITHUB_CLIENT_SECRET",
]


def require_env(name: str) -> str:
    """Get a required environment variable or exit with an error."""
    val = os.environ.get(name, "")
    if not val:
        print(f"ERROR: required environment variable {name} is not set", file=sys.stderr)
        sys.exit(1)
    return val


def opt_env(name: str, default: str = "") -> str:
    """Get an optional environment variable with a default."""
    return os.environ.get(name, default)


def random_token(length: int = 32) -> str:
    """Generate a URL-safe random token of exactly `length` characters."""
    return secrets.token_urlsafe(length)[:length]


def random_hex(length: int = 32) -> str:
    """Generate a random hex string of exactly `length` characters."""
    return secrets.token_hex(length // 2 + 1)[:length]


def make_jwt(payload: dict, secret: str) -> str:
    """Create an HS256 JWT using stdlib only (no PyJWT dependency)."""
    header = base64.urlsafe_b64encode(
        json.dumps({"alg": "HS256", "typ": "JWT"}).encode()
    ).rstrip(b"=")
    body = base64.urlsafe_b64encode(json.dumps(payload).encode()).rstrip(b"=")
    sig_input = header + b"." + body
    sig = base64.urlsafe_b64encode(
        hmac.new(secret.encode(), sig_input, hashlib.sha256).digest()
    ).rstrip(b"=")
    return (sig_input + b"." + sig).decode()


def get_argocd_server_secretkey() -> str:
    """Read server.secretkey from the argocd-secret in the cluster."""
    result = subprocess.run(
        [
            "kubectl",
            "get",
            "secret",
            "argocd-secret",
            "-n",
            "argo-cd",
            "-o",
            "jsonpath={.data.server\\.secretkey}",
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(
            f"ERROR: could not read argocd-secret: {result.stderr.strip()}",
            file=sys.stderr,
        )
        sys.exit(1)
    b64_key = result.stdout.strip()
    return base64.b64decode(b64_key).decode()


def compute_argocd_client_secret(server_secretkey: str) -> str:
    """Derive the argo-cd Dex client secret from server.secretkey."""
    digest = hashlib.sha256(server_secretkey.encode()).digest()
    return base64.urlsafe_b64encode(digest).decode()[:40]


def make_htpasswd(username: str, password: str) -> str:
    """Generate an htpasswd entry using the htpasswd command."""
    result = subprocess.run(
        ["htpasswd", "-nb", username, password],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(f"ERROR: htpasswd failed: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


def main() -> None:
    output_dir = Path(sys.argv[1]) if len(sys.argv) > 1 else Path("/tmp/cluster-secrets")
    output_dir.mkdir(parents=True, exist_ok=True)

    # Validate required env vars
    missing = [v for v in REQUIRED_ENV if not os.environ.get(v)]
    if missing:
        print("ERROR: missing required environment variables:", file=sys.stderr)
        for v in missing:
            print(f"  {v}", file=sys.stderr)
        sys.exit(1)

    # External credentials
    github_client_id = require_env("GITHUB_CLIENT_ID")
    github_client_secret = require_env("GITHUB_CLIENT_SECRET")
    cloudflare_api_token = require_env("CLOUDFLARE_API_TOKEN")
    cloudflare_tunnel_token = require_env("CLOUDFLARE_TUNNEL_TOKEN")
    oauth2_proxy_client_id = require_env("OAUTH2_PROXY_CLIENT_ID")
    oauth2_proxy_client_secret = require_env("OAUTH2_PROXY_CLIENT_SECRET")
    open_brain_github_client_id = require_env("OPEN_BRAIN_GITHUB_CLIENT_ID")
    open_brain_github_client_secret = require_env("OPEN_BRAIN_GITHUB_CLIENT_SECRET")

    # Admin password
    admin_password = opt_env("ADMIN_PASSWORD") or random_token(24)

    # ArgoCD server.secretkey (read from cluster)
    print("Reading argocd-secret server.secretkey from cluster...")
    server_secretkey = get_argocd_server_secretkey()
    argocd_client_secret = compute_argocd_client_secret(server_secretkey)

    # Generate random Dex static client secrets
    monitor_secret = random_hex(32)
    grafana_secret = random_hex(32)
    openwebui_secret = random_hex(32)

    # Cookie secrets (exactly 32 bytes for AES)
    monitor_cookie_secret = random_token(32)
    oauth2_proxy_cookie_secret = random_token(32)

    # Supabase secrets
    supabase_jwt_secret = random_hex(64)
    supabase_password = random_token(24)
    supabase_dashboard_password = random_token(24)
    supabase_public_access_token = random_token(32)
    supabase_private_access_token = random_token(32)
    supabase_secret_key_base = random_hex(128)
    supabase_crypto_key = random_hex(64)

    # Supabase JWTs
    now = int(time.time())
    exp = now + 10 * 365 * 24 * 3600  # 10 years
    anon_key = make_jwt(
        {"role": "anon", "iss": "supabase", "iat": now, "exp": exp},
        supabase_jwt_secret,
    )
    service_key = make_jwt(
        {"role": "service_role", "iss": "supabase", "iat": now, "exp": exp},
        supabase_jwt_secret,
    )

    # Supabase DATABASE_URL for open-brain-mcp
    database_url = f"postgresql://supabase_admin:{supabase_password}@supabase-supabase-db.supabase.svc:5432/postgres"

    # Other random tokens
    mcp_jwt_secret = random_token(32)
    supabase_mcp_access_key = random_token(32)

    # Admin htpasswd
    htpasswd = make_htpasswd("admin", admin_password)

    # Build the extracted-secrets.json format
    extracted: list[dict] = []

    # 1. argocd-dex-secret
    extracted.append({
        "namespace": "argo-cd",
        "name": "argocd-dex-secret",
        "data": {
            "dex.github.clientID": github_client_id,
            "dex.github.clientSecret": github_client_secret,
            "argo-cd.clientSecret": argocd_client_secret,
            "argocd.clientSecret": argocd_client_secret,
            "argocd-monitor.clientSecret": monitor_secret,
            "grafana.clientSecret": grafana_secret,
            "open-webui.clientSecret": openwebui_secret,
        },
    })

    # 2. argocd-monitor-oauth
    extracted.append({
        "namespace": "argocd-monitor",
        "name": "argocd-monitor-oauth",
        "data": {
            "client-secret": monitor_secret,
            "cookie-secret": monitor_cookie_secret,
        },
    })

    # 3. grafana-oauth-secret
    extracted.append({
        "namespace": "monitoring",
        "name": "grafana-oauth-secret",
        "data": {
            "CLIENT_SECRET": grafana_secret,
        },
    })

    # 4. open-webui-oauth-secret
    extracted.append({
        "namespace": "open-webui",
        "name": "open-webui-oauth-secret",
        "data": {
            "client-secret": openwebui_secret,
        },
    })

    # 4b. alertmanager-slack-secret (optional — only included if URL provided)
    slack_webhook_url = opt_env("SLACK_WEBHOOK_URL")
    if slack_webhook_url:
        extracted.append({
            "namespace": "monitoring",
            "name": "alertmanager-slack-secret",
            "data": {
                "webhook-url": slack_webhook_url,
            },
        })

    # 5. cloudflare-api-token
    extracted.append({
        "namespace": "cert-manager",
        "name": "cloudflare-api-token",
        "data": {
            "api-token": cloudflare_api_token,
        },
    })

    # 6. cloudflared-credentials
    extracted.append({
        "namespace": "cloudflared",
        "name": "cloudflared-credentials",
        "data": {
            "TUNNEL_TOKEN": cloudflare_tunnel_token,
        },
    })

    # 7. oauth2-proxy-credentials
    extracted.append({
        "namespace": "oauth2-proxy",
        "name": "oauth2-proxy-credentials",
        "data": {
            "client-id": oauth2_proxy_client_id,
            "client-secret": oauth2_proxy_client_secret,
            "cookie-secret": oauth2_proxy_cookie_secret,
        },
    })

    # 8. open-brain-mcp-secret
    extracted.append({
        "namespace": "open-brain-mcp",
        "name": "open-brain-mcp-secret",
        "data": {
            "GITHUB_CLIENT_ID": open_brain_github_client_id,
            "GITHUB_CLIENT_SECRET": open_brain_github_client_secret,
            "MCP_JWT_SECRET": mcp_jwt_secret,
            "DATABASE_URL": database_url,
            "SUPABASE_SERVICE_KEY": service_key,
        },
    })

    # 9. supabase-credentials
    extracted.append({
        "namespace": "supabase",
        "name": "supabase-credentials",
        "data": {
            "secret": supabase_jwt_secret,
            "anonKey": anon_key,
            "serviceKey": service_key,
            "password": supabase_password,
            "dashboard-password": supabase_dashboard_password,
            "database": "postgres",
            "username": "supabase_admin",
            "smtp-username": opt_env("SMTP_USERNAME"),
            "smtp-password": opt_env("SMTP_PASSWORD"),
            "openAiApiKey": opt_env("OPENAI_API_KEY"),
            "publicAccessToken": supabase_public_access_token,
            "privateAccessToken": supabase_private_access_token,
            "secretKeyBase": supabase_secret_key_base,
            "cryptoKey": supabase_crypto_key,
        },
    })

    # 10. supabase-mcp-env
    extracted.append({
        "namespace": "supabase",
        "name": "supabase-mcp-env",
        "data": {
            "MCP_ACCESS_KEY": supabase_mcp_access_key,
        },
    })

    # 11-12. admin-auth (longhorn, monitoring)
    for ns in ["longhorn", "monitoring"]:
        extracted.append({
            "namespace": ns,
            "name": "admin-auth",
            "data": {
                "auth": htpasswd,
                "user": "admin",
                "password": admin_password,
            },
        })

    # 14. argocd-secret (for reference, not re-sealed)
    extracted.append({
        "namespace": "argo-cd",
        "name": "argocd-secret",
        "data": {
            "server.secretkey": server_secretkey,
        },
    })

    # Write JSON
    dest = output_dir / "generated-secrets.json"
    dest.write_text(json.dumps(extracted, indent=2) + "\n")
    print(f"Wrote {dest} ({len(extracted)} secrets)")

    # Write admin password to a separate file for easy retrieval
    admin_file = output_dir / "admin-password.txt"
    admin_file.write_text(admin_password + "\n")
    print(f"Wrote {admin_file}")
    print(f"\nAdmin password: {admin_password}")


if __name__ == "__main__":
    main()
