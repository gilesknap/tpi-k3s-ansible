#!/usr/bin/env bash
# seal-headlamp-oidc — create a SealedSecret for Headlamp's Dex OIDC client.
#
# The client secret must match the value sealed in argocd-dex-secret
# under the key headlamp.clientSecret. Prompts for credentials
# interactively so nothing appears in shell history.
#
# Prerequisites:
#   - kubectl configured with access to the cluster
#   - kubeseal installed (https://github.com/bitnami-labs/sealed-secrets)
#   - ArgoCD Dex already configured with the headlamp static client
#
# Usage:
#   ./scripts/seal-headlamp-oidc

set -euo pipefail

NAMESPACE=headlamp
SECRET_NAME=headlamp-oidc
OUTPUT=kubernetes-services/additions/dashboard/headlamp-oidc-secret.yaml

echo "=== Headlamp OIDC — Sealed Secret Generator ==="
echo
echo "The client secret must match the headlamp.clientSecret value"
echo "in the argocd-dex-secret SealedSecret."
echo

# Read cluster domain from group_vars for the issuer URL.
# Default to prompting if not parseable.
CLUSTER_DOMAIN=$(grep 'cluster_domain:' group_vars/all.yml | awk '{print $2}' 2>/dev/null || true)
if [[ -z "$CLUSTER_DOMAIN" ]]; then
    read -rp "Cluster domain (e.g. gkcluster.org): " CLUSTER_DOMAIN
fi
echo "Using cluster domain: $CLUSTER_DOMAIN"
echo

read -rsp "Headlamp OIDC client secret: " CLIENT_SECRET; echo

if [[ -z "$CLIENT_SECRET" ]]; then
    echo "Error: client secret is required."
    exit 1
fi

ISSUER_URL="https://argocd.${CLUSTER_DOMAIN}/api/dex"

echo "Sealing secret..."
kubectl create secret generic "$SECRET_NAME" \
  --namespace="$NAMESPACE" \
  --from-literal=clientID="headlamp" \
  --from-literal=clientSecret="$CLIENT_SECRET" \
  --from-literal=issuerURL="$ISSUER_URL" \
  --from-literal=scopes="openid profile email" \
  --dry-run=client -o yaml | \
  kubeseal --format yaml \
    --controller-name sealed-secrets \
    --controller-namespace kube-system \
  > "$OUTPUT"

echo
echo "Sealed secret written to $OUTPUT"
echo "Commit this file and push — ArgoCD will deploy the secret."
