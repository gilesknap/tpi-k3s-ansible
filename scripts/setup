#!/usr/bin/env bash
# First-time devcontainer setup: verify the forwarded SSH agent and
# authenticate gh CLI.
#
# SSH keys and known_hosts are handled by VS Code Dev Containers — it forwards
# the host SSH agent via SSH_AUTH_SOCK and copies host ~/.ssh/known_hosts into
# the container on attach.
set -euo pipefail

echo "=== SSH agent (forwarded from host by VS Code) ==="
if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    echo "SSH_AUTH_SOCK is not set. VS Code Dev Containers forwards the host"
    echo "agent only if one is running when the container is launched. Start"
    echo "ssh-agent on the host (or unlock your KDE/GNOME keyring), add your"
    echo "ansible key with 'ssh-add', then reopen the container."
    exit 1
fi
if ! ssh-add -l >/dev/null 2>&1; then
    echo "Host ssh-agent is reachable but has no keys loaded."
    echo "On the host: ssh-add ~/.ssh/<your-ansible-key>"
    exit 1
fi
ssh-add -l

echo ""
echo "=== GitHub CLI authentication ==="
just gh-auth

echo ""
echo "Setup complete. Run 'claude' to start Claude Code."
