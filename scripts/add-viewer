#!/bin/bash
# Add a read-only (viewer) email to kubernetes-services/values.yaml.
# Usage: scripts/add-viewer <email>
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VALUES="$REPO_ROOT/kubernetes-services/values.yaml"

EMAIL="${1:-}"
if [ -z "$EMAIL" ]; then
    printf "Enter viewer email address: " && read EMAIL < /dev/tty
fi

# Validate email format (basic check)
if [[ ! "$EMAIL" =~ ^[^@]+@[^@]+\.[^@]+$ ]]; then
    echo "Error: '$EMAIL' does not look like a valid email address" >&2
    exit 1
fi

# Check if already present in admin_emails or viewer_emails
if yq '.admin_emails[]' "$VALUES" 2>/dev/null | grep -qxF "$EMAIL"; then
    echo "Error: '$EMAIL' is already in admin_emails" >&2
    exit 1
fi
if yq '.viewer_emails[]' "$VALUES" 2>/dev/null | grep -qxF "$EMAIL"; then
    echo "Error: '$EMAIL' is already in viewer_emails" >&2
    exit 1
fi

# Append to viewer_emails
yq -i ".viewer_emails += [\"$EMAIL\"]" "$VALUES"
echo "Added '$EMAIL' to viewer_emails in kubernetes-services/values.yaml"
echo ""
echo "Next steps:"
echo "  1. Commit and push to a branch"
echo "  2. Merge to main — ArgoCD will sync the new permissions automatically"
