#!/usr/bin/env bash
# seal-mcp-secret — create a SealedSecret for the Open Brain MCP server.
#
# Prompts for credentials interactively so nothing appears in shell history.
# Generates a random MCP_JWT_SECRET automatically.
#
# Prerequisites:
#   - kubectl configured with access to the cluster
#   - kubeseal installed (https://github.com/bitnami-labs/sealed-secrets)
#   - The Supabase stack deployed (for the database password)
#
# Usage:
#   ./scripts/seal-mcp-secret
#
# See docs/how-to/claude-ai-mcp.md for the full setup guide.

set -euo pipefail

NAMESPACE=open-brain-mcp
SECRET_NAME=open-brain-mcp-secret
OUTPUT=kubernetes-services/additions/open-brain-mcp/templates/open-brain-mcp-secret.yaml

echo "=== Open Brain MCP — Sealed Secret Generator ==="
echo

# Fetch the Supabase DB password and build the DATABASE_URL automatically.
echo "Fetching Supabase database password from cluster..."
DB_PASSWORD=$(kubectl get secret supabase-credentials -n supabase \
  -o jsonpath='{.data.password}' | base64 -d)
DATABASE_URL="postgresql://supabase_admin:${DB_PASSWORD}@supabase-supabase-db.supabase.svc.cluster.local:5432/postgres"
echo "DATABASE_URL constructed from supabase-credentials secret."
echo

# Prompt for GitHub OAuth App credentials (hidden input).
echo "Enter your GitHub OAuth App credentials (from https://github.com/settings/developers)."
read -rsp "GITHUB_CLIENT_ID: " GITHUB_CLIENT_ID; echo
read -rsp "GITHUB_CLIENT_SECRET: " GITHUB_CLIENT_SECRET; echo

if [[ -z "$GITHUB_CLIENT_ID" || -z "$GITHUB_CLIENT_SECRET" ]]; then
    echo "Error: both GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET are required."
    exit 1
fi

# Generate a random JWT signing secret.
MCP_JWT_SECRET=$(openssl rand -hex 32)
echo
echo "Generated MCP_JWT_SECRET (random 64-char hex)."

# Create namespace if it doesn't exist.
kubectl create namespace "$NAMESPACE" --dry-run=client -o yaml | kubectl apply -f -

# Create and seal the secret.
echo "Sealing secret..."
kubectl create secret generic "$SECRET_NAME" \
  --namespace="$NAMESPACE" \
  --from-literal=DATABASE_URL="$DATABASE_URL" \
  --from-literal=MCP_JWT_SECRET="$MCP_JWT_SECRET" \
  --from-literal=GITHUB_CLIENT_ID="$GITHUB_CLIENT_ID" \
  --from-literal=GITHUB_CLIENT_SECRET="$GITHUB_CLIENT_SECRET" \
  --dry-run=client -o yaml | \
  kubeseal --format yaml \
    --controller-name sealed-secrets \
    --controller-namespace kube-system \
  > "$OUTPUT"

echo
echo "Sealed secret written to $OUTPUT"
echo "Commit this file and push — ArgoCD will deploy the secret."
