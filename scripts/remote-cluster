#!/usr/bin/env bash
# remote-cluster — connect to the k3s cluster via Cloudflare SSH tunnel.
#
# Run this on your CLIENT machine (not inside the devcontainer).
#
# Usage:
#   remote-cluster                 # forward Kubernetes API + all web services
#   remote-cluster --kill          # tear down all forwards
#   remote-cluster --status        # show active forwards
#
# Prerequisites:
#   - cloudflared installed locally
#   - SSH config entry for SSH_HOST (see docs/how-to/cloudflare-ssh-tunnel.md)
#   - ~/.kube/k3s-remote.yaml with server set to https://127.0.0.1:6443
#   - ~/.remote-cluster.conf with your cluster settings (see below)
#
# Create ~/.remote-cluster.conf with at minimum:
#   SSH_HOST="ssh.yourdomain.com"
#   CONTROL_PLANE="node01.lan"
#
# You can also override port assignments and KUBECONFIG_FILE there.

set -euo pipefail

# Defaults — override any of these in ~/.remote-cluster.conf
SSH_HOST=""
CONTROL_PLANE=""
KUBECONFIG_FILE="$HOME/.kube/k3s-remote.yaml"
K8S_API_PORT=6443
ARGOCD_PORT=8080
GRAFANA_PORT=3000
HEADLAMP_PORT=4466
LONGHORN_PORT=8081
OPEN_WEBUI_PORT=8082

CONF_FILE="${REMOTE_CLUSTER_CONF:-$HOME/.remote-cluster.conf}"
if [[ -f "$CONF_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONF_FILE"
fi

if [[ -z "$SSH_HOST" || -z "$CONTROL_PLANE" ]]; then
    echo "Error: SSH_HOST and CONTROL_PLANE must be set."
    echo "Create $CONF_FILE with:"
    echo '  SSH_HOST="ssh.yourdomain.com"'
    echo '  CONTROL_PLANE="node01.lan"'
    exit 1
fi

PID_FILE="/tmp/remote-cluster.pids"

kill_forwards() {
    # Kill tracked PIDs from the PID file.
    if [[ -f "$PID_FILE" ]]; then
        while read -r pid; do
            kill "$pid" 2>/dev/null || true
        done < "$PID_FILE"
        rm -f "$PID_FILE"
    fi
    # Also kill any orphaned SSH tunnels to the same host (e.g. from a
    # previous run that didn't track PIDs correctly).
    pkill -f "ssh -NL.*${SSH_HOST}" 2>/dev/null || true
    echo "All port forwards stopped."
}

show_status() {
    if [[ -f "$PID_FILE" ]]; then
        local alive=0
        while read -r pid; do
            if kill -0 "$pid" 2>/dev/null; then
                alive=$((alive + 1))
            fi
        done < "$PID_FILE"
        echo "$alive active port forward(s)."
    else
        echo "No active port forwards."
    fi
}

start_forwards() {
    # Ensure any stale forwards are cleaned up first.
    kill_forwards 2>/dev/null || true
    : > "$PID_FILE"

    # Kubernetes API — SSH tunnel direct to control plane.
    # Authentication is handled by the ProxyCommand in ~/.ssh/config
    # (cloudflared access ssh). If your token has expired, the SSH
    # connection will trigger a browser login automatically.
    echo "Opening SSH tunnel to ${SSH_HOST}..."
    ssh -NL "${K8S_API_PORT}:${CONTROL_PLANE}:6443" "$SSH_HOST" &
    echo $! >> "$PID_FILE"

    # Wait for the API to become reachable before starting kubectl forwards.
    export KUBECONFIG="$KUBECONFIG_FILE"
    echo "Waiting for Kubernetes API..."
    for i in $(seq 1 30); do
        if kubectl cluster-info &>/dev/null; then
            break
        fi
        if [[ $i -eq 30 ]]; then
            echo "Timed out waiting for Kubernetes API."
            kill_forwards
            exit 1
        fi
        sleep 1
    done

    # Service port forwards via kubectl.
    kubectl port-forward svc/argocd-server     -n argo-cd    "${ARGOCD_PORT}:8080"  &>/dev/null &
    echo $! >> "$PID_FILE"
    kubectl port-forward sts/grafana-prometheus -n monitoring "${GRAFANA_PORT}:3000" &>/dev/null &
    echo $! >> "$PID_FILE"
    kubectl port-forward svc/headlamp          -n headlamp   "${HEADLAMP_PORT}:80"  &>/dev/null &
    echo $! >> "$PID_FILE"
    kubectl port-forward svc/longhorn-frontend  -n longhorn   "${LONGHORN_PORT}:80"  &>/dev/null &
    echo $! >> "$PID_FILE"
    kubectl port-forward svc/open-webui        -n open-webui "${OPEN_WEBUI_PORT}:80" &>/dev/null &
    echo $! >> "$PID_FILE"

    cat <<EOF

Remote cluster connected. Services available at:

  Kubernetes API  https://127.0.0.1:${K8S_API_PORT}
  ArgoCD          https://localhost:${ARGOCD_PORT}
  Grafana         http://localhost:${GRAFANA_PORT}
  Headlamp        http://localhost:${HEADLAMP_PORT}
  Longhorn        http://localhost:${LONGHORN_PORT}
  Open WebUI      http://localhost:${OPEN_WEBUI_PORT}

  KUBECONFIG=${KUBECONFIG_FILE}

Run 'remote-cluster --kill' to stop all forwards.
EOF
}

case "${1:-}" in
    --kill)   kill_forwards ;;
    --status) show_status ;;
    *)        start_forwards ;;
esac
