#!/usr/bin/env python3
"""Extract plaintext secrets from a running K3s cluster before teardown.

Outputs a JSON file suitable for `just seal-from-json` and backs up
sealed-secrets encryption keys. Used by the rebuild-cluster workflow
so secrets can be re-sealed after the cluster gets new encryption keys.

Usage:
    scripts/extract-secrets [OUTPUT_DIR]

Output_dir defaults to /tmp/cluster-secrets.  Two files are written:
    extracted-secrets.json   — JSON array consumed by `just seal-from-json`
    sealed-secrets-keys.yaml — sealed-secrets controller encryption keys
"""

from __future__ import annotations

import base64
import json
import subprocess
import sys
from pathlib import Path

# Secrets to extract: (namespace, name)
SECRETS = [
    ("argo-cd", "argocd-dex-secret"),
    ("argocd-monitor", "argocd-monitor-oauth"),
    ("cert-manager", "cloudflare-api-token"),
    ("cloudflared", "cloudflared-credentials"),
    ("monitoring", "alertmanager-slack-secret"),
    ("monitoring", "grafana-oauth-secret"),
    ("oauth2-proxy", "oauth2-proxy-credentials"),
    ("open-brain-mcp", "open-brain-mcp-secret"),
    ("open-webui", "open-webui-oauth-secret"),
    ("supabase", "supabase-credentials"),
    ("supabase", "supabase-mcp-env"),
    ("longhorn", "admin-auth"),
    ("monitoring", "admin-auth"),
    ("argo-cd", "argocd-secret"),
]


def kubectl_get_secret(namespace: str, name: str) -> dict[str, str] | None:
    """Return decoded data keys for a secret, or None if not found."""
    result = subprocess.run(
        [
            "kubectl",
            "get",
            "secret",
            name,
            "-n",
            namespace,
            "-o",
            "json",
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None

    secret = json.loads(result.stdout)
    raw_data = secret.get("data", {})
    decoded = {}
    for key, val in raw_data.items():
        try:
            decoded[key] = base64.b64decode(val).decode("utf-8", errors="replace")
        except Exception:
            decoded[key] = val
    return decoded


def backup_sealed_secrets_keys(output_dir: Path) -> None:
    """Backup sealed-secrets encryption keys to a YAML file."""
    result = subprocess.run(
        [
            "kubectl",
            "get",
            "secret",
            "-n",
            "kube-system",
            "-l",
            "sealedsecrets.bitnami.com/sealed-secrets-key",
            "-o",
            "yaml",
        ],
        capture_output=True,
        text=True,
    )
    dest = output_dir / "sealed-secrets-keys.yaml"
    if result.returncode != 0:
        print(f"WARNING: could not backup sealed-secrets keys: {result.stderr.strip()}", file=sys.stderr)
        return
    dest.write_text(result.stdout)
    print(f"Wrote {dest}")


def main() -> None:
    output_dir = Path(sys.argv[1]) if len(sys.argv) > 1 else Path("/tmp/cluster-secrets")
    output_dir.mkdir(parents=True, exist_ok=True)

    extracted: list[dict] = []
    for namespace, name in SECRETS:
        data = kubectl_get_secret(namespace, name)
        if data is None:
            print(f"WARNING: secret {namespace}/{name} not found, skipping", file=sys.stderr)
            continue
        extracted.append({"namespace": namespace, "name": name, "data": data})
        print(f"Extracted: {namespace}/{name} ({len(data)} keys)")

    dest = output_dir / "extracted-secrets.json"
    dest.write_text(json.dumps(extracted, indent=2) + "\n")
    print(f"\nWrote {dest} ({len(extracted)}/{len(SECRETS)} secrets)")

    backup_sealed_secrets_keys(output_dir)

    if len(extracted) < len(SECRETS):
        missing = len(SECRETS) - len(extracted)
        print(f"\nWARNING: {missing} secret(s) could not be extracted", file=sys.stderr)


if __name__ == "__main__":
    main()
