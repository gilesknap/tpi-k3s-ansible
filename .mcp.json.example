{
  "mcpServers": {
    "open-brain": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--project", "open-brain-cli", "python", "open-brain-cli/server.py"],
      "env": {
        "BRAIN_API_URL": "${BRAIN_API_URL}",
        "BRAIN_API_KEY": "${BRAIN_API_KEY}",
        "BRAIN_SERVICE_KEY": "${BRAIN_SERVICE_KEY}"
      }
    }
  }
}
