---
# Ansible-lint configuration

# Exclude paths that contain Helm/Jinja2 templates (not Ansible playbooks)
exclude_paths:
  - kubernetes-services/
  - build/

# Pre-existing violations — treat as warnings so CI passes while we
# clean them up incrementally.
warn_list:
  - command-instead-of-module
  - name[template]
  - package-latest
  - risky-shell-pipe
  - var-naming[no-role-prefix]
  - yaml[indentation]
  - yaml[line-length]
