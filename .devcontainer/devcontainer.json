// For format details, see https://containers.dev/implementors/json_reference/
{
	"name": "K3s Cluster Ansible Execution Environment",
	"build": {
		"dockerfile": "Dockerfile",
		"target": "developer"
	},
	// enable ping to test connectivity
	"runArgs": [
		"--net=host",
		"--security-opt=label=disable"
	],
	// reserve some ports for port forwarding with kubectl - because when auto
	// port forward goes wrong things get nasty
	"appPort": [
		8443, // dashboard
		3000 // grafana
	],
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "/cache/venv-for${localWorkspaceFolder}/bin/python",
				"dev.containers.copyGitConfig": true,
				"remote.autoForwardPorts": false,
				"remote.restoreForwardedPorts": false,
				"remote.forwardOnOpen": false,
			},
			"extensions": [
				"streetsidesoftware.code-spell-checker-cspell-bundled-dictionaries",
				"redhat.ansible",
				"ms-kubernetes-tools.vscode-kubernetes-tools",
				"tamasfe.even-better-toml",
				"redhat.vscode-yaml",
				"Anthropic.claude-code"
			]
		}
	},
	// For rootless we must be root account
	"remoteUser": "root",
	// mount in useful files and configuration folders - those updated by ansible
	// are stored in volumes so they persist between container runs
	"mounts": [
		// Note - password file is not currently used
		"source=${localEnv:HOME}/.ansible_vault_password,target=/etc/ansible/.vault_password.txt,type=bind,ro",
		"source=iac2-bin,target=/root/bin,type=volume",
		// /root/.ssh is left to VS Code Dev Containers: it auto-forwards the
		// host SSH agent via SSH_AUTH_SOCK and copies host known_hosts on
		// attach. Claude is isolated from both by the bwrap sandbox.
		"source=iac2-kube,target=/root/.kube,type=volume",
		// Claude-scoped SSH keypair for ansible on cluster nodes. Separate
		// from the user's personal keys (which never enter the sandbox).
		// Bootstrap with `just claude-ssh-bootstrap`.
		"source=iac2-claude-ssh,target=/root/.config/claude-ssh,type=volume",
		// Mount in the user terminal config folder so it can be edited
		{
			"source": "${localEnv:HOME}/.config/terminal-config",
			"target": "/user-terminal-config",
			"type": "bind"
		},
		// Keep a persistent cross container cache for uv, pre-commit, and the venvs
		{
			"source": "devcontainer-shared-cache",
			"target": "/cache",
			"type": "volume"
		},
		// Persist gh auth across container rebuilds with per-repo scoped PAT
		{
			"source": "gh-auth-${localWorkspaceFolderBasename}",
			"target": "/root/.config/gh",
			"type": "volume"
		}
	],
	"remoteEnv": {
		"ANSIBLE_VAULT_PASSWORD_FILE": "/etc/ansible/.vault_password.txt",
		"ZSHRC": "/bash-config/zshrc",
		"BIN_DIR": "/root/bin",
		// Put things that allow it in the persistent cache
		"PRE_COMMIT_HOME": "/cache/pre-commit",
		"UV_CACHE_DIR": "/cache/uv",
		"UV_PYTHON_CACHE_DIR": "/cache/uv-python",
		"UV_PROJECT_ENVIRONMENT": "/cache/venv-for${localWorkspaceFolder}",
		"VIRTUAL_ENV": "/cache/venv-for${localWorkspaceFolder}",
		"PATH": "/cache/venv-for${localWorkspaceFolder}/bin:${containerEnv:PATH}"
	},
	// For rootless leave the filesystem owned by root
	"updateRemoteUserUID": false,
	// make sure files are available for mounting
	"initializeCommand": ".devcontainer/initializeCommand.sh",
	// One time global setup commands inside the container
	"postCreateCommand": ".devcontainer/postCreate.sh",
	"postStartCommand": ".devcontainer/postStart.sh",
	// Mount the parent of the project folder so we can access peer projects
	"workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspaces,type=bind"
}
